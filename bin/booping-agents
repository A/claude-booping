#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml>=6.0"]
# ///
"""booping-agents: enumerate available agents for inlining into /help."""
import sys
from pathlib import Path

import yaml

REPO_ROOT = Path(__file__).resolve().parent.parent
AGENTS_DIR = REPO_ROOT / "agents"


def extract_frontmatter(path: Path) -> dict:
    text = path.read_text()
    if not text.startswith("---\n"):
        return {}
    try:
        rest = text[4:]
        fm_text, _ = rest.split("\n---", 1)
        return yaml.safe_load(fm_text) or {}
    except (ValueError, yaml.YAMLError):
        return {}


def main() -> int:
    entries = []
    for agent_md in sorted(AGENTS_DIR.glob("*.md")):
        fm = extract_frontmatter(agent_md)
        entries.append(
            {
                "name": agent_md.stem,
                "description": fm.get("description") or "",
                "model": fm.get("model") or "",
            }
        )

    print("## Agents\n")
    print("| Agent | Description | Model |")
    print("|-------|-------------|-------|")
    for e in entries:
        print(f"| `{e['name']}` | {e['description']} | {e['model']} |")

    return 0


if __name__ == "__main__":
    sys.exit(main())

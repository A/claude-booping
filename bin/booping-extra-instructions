#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml>=6.0"]
# ///
"""booping-extra-instructions: print a user-specific instructions block for a skill.

Reads `~/Claude/{project}/_booping/<filename>` and, if present, prints a
framed "User-specific instructions" block containing the file body. Prints
nothing when the project is not initialized or the file does not exist.

Designed to be inlined via `!`bin/booping-extra-instructions <filename>``
at skill-load time, so each skill can carry per-project overrides without
an extra read step.
"""
import sys
from pathlib import Path

import yaml


def project_booping_dir() -> Path | None:
    path = Path.cwd() / ".booping"
    if not path.exists():
        return None
    try:
        data = yaml.safe_load(path.read_text()) or {}
    except yaml.YAMLError:
        return None
    name = data.get("project_name") if isinstance(data, dict) else None
    if not isinstance(name, str) or not name:
        return None
    return Path.home() / "Claude" / name / "_booping"


def main() -> int:
    if len(sys.argv) != 2:
        print("usage: booping-extra-instructions <filename>", file=sys.stderr)
        return 2
    base = project_booping_dir()
    if base is None:
        return 0
    target = base / sys.argv[1]
    if not target.exists():
        return 0
    body = target.read_text().strip()
    if not body:
        return 0
    print("## User-specific instructions")
    print()
    print(
        "These instructions come from prior coding sessions and user feedback "
        "in this project. They override the skill instructions above — where "
        "they disagree, follow these."
    )
    print()
    print(body)
    return 0


if __name__ == "__main__":
    sys.exit(main())

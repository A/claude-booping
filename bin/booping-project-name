#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml>=6.0"]
# ///
"""booping-project-name: print project context for embedding into a skill.

Used by skills via `!`bin/booping-project-name`` to resolve project
context at skill-load time. Output is a self-contained markdown chunk the
skill can render verbatim — the skill does not need to branch on state.

Two output shapes:

1. Initialized (`.booping` in cwd with a valid `project_name`):

       ```yaml
       name: claude-booping
       directory: /home/anton/Claude/claude-booping
       ```

2. Not initialized (no `.booping`, or malformed, or missing `project_name`):

       Project not initialized. ... See <abs path to how_to_initialize_project.md>
       for the onboarding procedure. Do this before proceeding with the user's
       original request.
"""
import sys
from pathlib import Path

import yaml

REPO_ROOT = Path(__file__).resolve().parent.parent
INIT_DOC = REPO_ROOT / "src" / "docs" / "how_to_initialize_project.md"


def resolve() -> tuple[str | None, Path | None]:
    path = Path.cwd() / ".booping"
    if not path.exists():
        return None, None
    try:
        data = yaml.safe_load(path.read_text()) or {}
    except yaml.YAMLError:
        return None, None
    name = data.get("project_name") if isinstance(data, dict) else None
    if not isinstance(name, str) or not name:
        return None, None
    return name, Path.home() / "Claude" / name


def render_initialized(name: str, directory: Path) -> str:
    return f"```yaml\nname: {name}\ndirectory: {directory}\n```"


def render_uninitialized() -> str:
    return (
        "Project not initialized — no `.booping` file in the current directory. "
        "Before proceeding with the user's request, onboard them per the procedure in "
        f"`{INIT_DOC}`. Read that file, walk the user through it, then retry."
    )


def main() -> int:
    name, directory = resolve()
    if name and directory:
        print(render_initialized(name, directory))
    else:
        print(render_uninitialized())
    return 0


if __name__ == "__main__":
    sys.exit(main())

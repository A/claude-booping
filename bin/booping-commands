#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
"""booping-commands: print the /help slash-command index.

Used by /help via `!`bin/booping-commands``. The "First time in a repo: /install"
line is shown only when the cwd has no `.booping` marker — once a project is
resolved, that line is noise. Human-in-the-loop checkpoints are surfaced as
indented continuation lines under the command they follow.
"""
import sys
from pathlib import Path


def is_initialized() -> bool:
    return (Path.cwd() / ".booping").is_file()


def main() -> int:
    rows: list[tuple[str, str] | str] = []
    if not is_initialized():
        rows.append(("First time in a repo:", "/install"))
    rows.extend([
        ("Start a discussion:", "/chat"),
        ("Spec new work:", "/groom <topic>"),
        "  ↳ review the plan, refine scope and acceptance criteria — better plan, better results",
        ("Execute a plan:", "/develop ~/Claude/<project>/plans/YYYYMMDD-*.md"),
        "  ↳ code-review the diff and address feedback before retro",
        ("After a sprint ships:", "/retro ~/Claude/<project>/plans/YYYYMMDD-*.md"),
        ("Extract lessons:", "/learn [~/Claude/<project>/retrospectives/YYYYMMDD-*.md]"),
    ])
    width = max(len(row[0]) for row in rows if isinstance(row, tuple))
    print("## Commands\n")
    print("```")
    print("booping — per-project grooming / implementation / retro / lessons with mandatory sub-agent delegation")
    print()
    for row in rows:
        if isinstance(row, tuple):
            label, cmd = row
            print(f"{label:<{width}}  {cmd}")
        else:
            print(row)
    print("```")
    print()
    print("Artifacts live at `~/Claude/{project}/`.")
    return 0


if __name__ == "__main__":
    sys.exit(main())

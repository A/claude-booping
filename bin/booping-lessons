#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml>=6.0"]
# ///
"""booping-lessons: print the full lesson corpus for the current project.

Enumerates `~/Claude/{project}/lessons/*.md` in filename order, emits a
Lessons block with an index and each lesson's full body, and trails a short
rule about handling conflicts. Prints nothing when the project is not
initialized. Designed to be inlined via `!`bin/booping-lessons`` at
skill-load time so every skill starts with the active rules in context.
"""
import sys
from pathlib import Path

import yaml


def lessons_dir() -> Path | None:
    path = Path.cwd() / ".booping"
    if not path.exists():
        return None
    try:
        data = yaml.safe_load(path.read_text()) or {}
    except yaml.YAMLError:
        return None
    name = data.get("project_name") if isinstance(data, dict) else None
    if not isinstance(name, str) or not name:
        return None
    return Path.home() / "Claude" / name / "lessons"


def parse(text: str) -> tuple[dict, str]:
    if not text.startswith("---\n"):
        return {}, text
    end = text.find("\n---\n", 4)
    if end == -1:
        return {}, text
    try:
        fm = yaml.safe_load(text[4:end]) or {}
    except yaml.YAMLError:
        fm = {}
    body = text[end + 5 :].lstrip("\n")
    return (fm if isinstance(fm, dict) else {}), body


def main() -> int:
    base = lessons_dir()
    if base is None or not base.exists():
        return 0
    files = sorted(p for p in base.glob("*.md") if p.is_file())
    print("## Lessons")
    print()
    if not files:
        print("No lessons accumulated yet in this project.")
        return 0
    print(
        f"The following {len(files)} lesson(s) are loaded for the rest of the "
        "session. Keep them in context; never silently violate a loaded "
        "lesson. If one conflicts with a user request, plan decision, or "
        "in-progress task, stop and flag it before continuing."
    )
    print()
    print("### Index")
    print()
    entries = []
    for path in files:
        fm, body = parse(path.read_text())
        title = fm.get("title") or path.stem
        entries.append((path, fm, body, title))
        print(f"- `{path.name}` — {title}")
    for path, fm, body, title in entries:
        print()
        print(f"### {path.stem} — {title}")
        print()
        print(body.rstrip())
    return 0


if __name__ == "__main__":
    sys.exit(main())

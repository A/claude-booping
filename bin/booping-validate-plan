#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "google-genai>=0.3.0",
# ]
# ///
"""Cross-validate a booping backlog item with Gemini, grading it against
the project's lessons as a strict rubric.

Installed on PATH automatically when the booping plugin is enabled.

Usage:
    booping-validate-plan <backlog-file-path>

Backlog file must live at ~/Claude/{project}/backlog/*.md — the script
derives the project from the path and loads that project's lessons.
"""

import os
import sys
from pathlib import Path

import google.genai as genai

CLAUDE_ROOT = Path.home() / "Claude"


def resolve_lessons_dir(plan_path: Path) -> Path | None:
    """Find ~/Claude/{project}/lessons/ given a backlog file inside that project."""
    try:
        rel = plan_path.resolve().relative_to(CLAUDE_ROOT.resolve())
    except ValueError:
        return None
    if not rel.parts:
        return None
    project = rel.parts[0]
    lessons = CLAUDE_ROOT / project / "lessons"
    return lessons if lessons.is_dir() else None


def load_lessons(lessons_dir: Path | None) -> str:
    if lessons_dir is None:
        return "(No project lessons directory resolved — skipping lesson-based validation.)"

    lesson_files = sorted(lessons_dir.glob("*.md"))
    if not lesson_files:
        return "(No lesson files found — skipping lesson-based validation.)"

    rules: list[str] = []
    rule_num = 0
    for path in lesson_files:
        text = path.read_text()
        in_rule = False
        current_rule = ""
        for line in text.splitlines():
            if line.startswith("### ") and line[4:5].isdigit():
                if in_rule and current_rule.strip():
                    rule_num += 1
                    rules.append(f"{rule_num}. {current_rule.strip()}")
                current_rule = line.lstrip("# ").lstrip("0123456789. ") + "\n"
                in_rule = True
            elif in_rule:
                current_rule += line + "\n"
        if in_rule and current_rule.strip():
            rule_num += 1
            rules.append(f"{rule_num}. {current_rule.strip()}")

    if not rules:
        fallback = "\n\n".join(
            f"{i+1}. {p.read_text().strip()}" for i, p in enumerate(lesson_files)
        )
        return fallback or "(No rules extracted from lesson files.)"

    return "\n\n".join(rules)


def build_prompt(plan_content: str, lessons_text: str) -> str:
    return f"""You are a strict Staff Software Engineer reviewing a technical sprint plan that will be executed by an AI coding agent (Claude Code).

Your mandate is to find execution gaps, architectural blind spots, and violations of our team's engineering rules. Do NOT give generic software engineering advice. If the plan is vague, flag it as a risk. Every piece of feedback must reference a specific part of the plan.

---

## Dimension 1: Team Engineering Rules

Review the plan against these historical lessons. If the plan introduces a pattern that violates any rule, flag it explicitly with the rule number.

{lessons_text}

---

## Dimension 2: AI Execution Completeness

AI agents fail when plans are ambiguous. They cannot infer implicit context. Evaluate:

* **Unresolved Variables:** Does the plan use vague terms like "update the handler", "refactor the service", or "add error handling" without specifying exact file paths, class names, and function signatures? Each such instance is a critical risk.
* **Data Flow & Types:** Are input/output types of new services/functions explicitly defined? Is there a risk of creating parallel types for the same domain concept (violates canonical type rule)?
* **Concurrency & Failure Modes:** If the plan involves async tasks, external API calls, or database writes, does it explicitly state error-handling, retry, and idempotency strategy? Or is it left implicit?
* **Coupling & I/O Boundaries:** Does the plan tightly couple business logic to frameworks, I/O, or external services instead of using dependency injection or composition?
* **Test Strategy Gaps:** Does the plan specify where test utilities go? Does it avoid stuffing logic into conftest.py? Are test boundaries clear?

---

## Required Output Format

Use EXACTLY these three sections. Be concise. Use bullet points. Reference specific plan sections/tasks by name or number. Provide short code/pseudo-code examples only when suggesting a concrete fix.

### CRITICAL EXECUTION RISKS
Ambiguities or missing details that will cause an AI agent to fail, guess wrong, or write bad code. Each item must quote the vague part of the plan and state what's missing.

### RULE VIOLATIONS
Direct conflicts with Team Engineering Rules above. Reference the rule number and the specific plan element that violates it.

### ARCHITECTURAL BLIND SPOTS
Concurrency, state management, coupling, or data integrity issues that the plan doesn't address. Only flag issues that are specific to THIS plan — no generic advice.

If a section has no issues, write "None found." Do not pad sections with generic advice.

---

## Sprint Plan Under Review:

{plan_content}"""


EXIT_OK = 0
EXIT_ERROR = 1
EXIT_SKIPPED = 2


def validate_plan(plan_file: Path) -> int:
    if not plan_file.exists():
        print(f"Plan file not found: {plan_file}", file=sys.stderr)
        return EXIT_ERROR

    plan_content = plan_file.read_text()
    api_key = os.environ.get("GEMINI_API_KEY")
    if not api_key:
        print(
            "GEMINI_API_KEY not set in environment — skipping cross-validation.",
            file=sys.stderr,
        )
        return EXIT_SKIPPED

    lessons_text = load_lessons(resolve_lessons_dir(plan_file))

    os.environ.pop("GOOGLE_API_KEY", None)
    client = genai.Client(api_key=api_key)
    model = os.environ.get("BOOPING_VALIDATOR_MODEL", "gemini-3.1-pro-preview")

    prompt_text = build_prompt(plan_content, lessons_text)

    try:
        response = client.models.generate_content(model=model, contents=prompt_text)
        print(f"\n--- Plan Validation: {plan_file.name} ---\n")
        print(response.text)
    except Exception as e:
        print(f"Validator request failed: {e}", file=sys.stderr)
        return EXIT_ERROR

    return EXIT_OK


if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("Usage: booping-validate-plan <backlog-file-path>", file=sys.stderr)
        sys.exit(EXIT_ERROR)

    plan_path = Path(sys.argv[1]).expanduser()
    sys.exit(validate_plan(plan_path))

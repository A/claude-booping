#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml>=6.0"]
# ///
"""booping-sprint-threshold: print the SP total above which /groom should suggest splitting a plan.

Not a velocity — there is no fixed cadence. This is a heuristic ceiling:
past this point the plan is probably too large to hold together and /groom
should propose splitting into sibling plans.

Today this is a static echo of `sprint.default_threshold_sp` from
`src/config.yaml`. Later it may learn from how users actually split plans.
Callers inline the number via `!`bin/booping-sprint-threshold``.
"""
import sys
from pathlib import Path

import yaml

CONFIG_FILE = Path(__file__).resolve().parent.parent / "src" / "config.yaml"


def main() -> int:
    data = yaml.safe_load(CONFIG_FILE.read_text()) or {}
    sprint = data.get("sprint") or {}
    value = sprint.get("default_threshold_sp")
    if not isinstance(value, int):
        print("sprint.default_threshold_sp missing from src/config.yaml", file=sys.stderr)
        return 1
    print(value)
    return 0


if __name__ == "__main__":
    sys.exit(main())
